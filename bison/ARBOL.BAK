%{
#include<stdio.h>
#include<stdlib.h>
#include<graphics.h>
#include<conio.h>
#include<math.h>
#include "c:\tc\bin\flex\lexyy.c"
int linea2=1;
void yyerror(char*);
int con=0,a=0,z=0;



typedef struct  pila {
	int corx;
	int cory;
	  }pila;



void linea(float);
pila mipila[100];
int loop=0;
void linea(float g)
{

float x,x1,y,y1, tmp,pi=3.1415926535897932384626433832795;

		if (g==-1)
	{mipila[loop].corx=a;
	 mipila[loop].cory=z;
	 loop++;

	 }
  else
   {
   if (g==-2)
	 {
	  a=mipila[loop-1].corx;
	  z=mipila[loop-1].cory;
	  loop--;
	 }
	else
	{
	if (con==0)
	  {
		a=getmaxx()/2;
		z=getmaxy()/2;
		con++;
	   }
	   g=g+90;
	   g=g*(pi/180);
	   tmp=sin(g)*20;
	   x=tmp;
	   tmp=cos(g)*20;
	   y=tmp;
		   x=x+(a);
	   y=y+(z);
	   moveto(x,y);
	  lineto(a,z);
	  a=x; z=y;

		 }
	}
 }




%}
%union{
	int numero;


}
%token ARRIBA
%token ABAJO
%token GIZQ
%token GDER
%token GUARDAPOS
%token LEEPOS
%token <numero>NUM




%type <numero> sent

%start prog

%%
prog :	prog  sent
	| prog error ';' {yyerrok}
	|
	;


sent :
	   ARRIBA{linea(90);}
	|ABAJO{linea(270);}
	|GDER NUM{linea(90-$2);}
	|GIZQ NUM{linea(90+$2);}
	|GUARDAPOS{linea(-1);}
	|LEEPOS{linea(-2);}
					   ;


%%
void main()
{
int gdriver = DETECT, gmode, errorcode;
   char msg[80];

	initgraph(&gdriver, &gmode, "./bgi");


   errorcode = graphresult();
   if (errorcode != grOk)
   {
	  printf("Graphics error: %s\n", grapherrormsg(errorcode));
	  printf("Press any key to halt:");
	  getch();
	  exit(1);
   }

yyin=fopen("c:\\tc\\bin\\bison\\fuente.txt","rt");

yyparse();
getch();
}
void yyerror (char *s)
{
  printf ("Error en linea %d : %s\n", linea2, s);
}


