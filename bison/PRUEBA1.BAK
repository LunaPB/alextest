%{
#include <math.h>
#include <stdio.h>
#include <stdlib.h>
#include <mem.h>
#include <ctype.h>
#include <conio.h>
#include<string.h>
#include <process.h>
#include <math.h>
void yyerror(char*);
FILE *yyin, *yyout;
char cont[10];
int con=0;
int x=0;
%}

%union {char identificador;
	int constante;
	}
%token <identificador>LETRAS_MIN

%%

programa:/*vacio*/
	 'M' '{' inicio variables '}'

;
inicio: {printf(".CODE\n");}
;
variables: /*vacio*/
	  | 'R' LETRAS_MIN ';' variables { for(x=0;x<con;x++)
					   {
					   printf("INPUT %c \n",cont[x]);
					   }
					    con=0;
					  }


%%

//aqui empieza analizador l‚xico

int yylex(void)
{
  int c;
  while((c=getc(yyin))!=EOF)
  {
   if((c==' ') || (c=='\t'))continue;
     if(c=='\n')
      { //linea++;
       continue; }

     if(islower(c))//letras minusculas
     {
      yylval.identificador=c;
      cont[con]=yylval.identificador;
      con++;
      return LETRAS_MIN;
     }

     return c;
  }

  return 0;
}

//principal

void main()
{
   clrscr();
  if((yyin=fopen("c:\\fuente.txt","r"))==NULL)
  {
   printf("No se puede abrir el fichero fuente -> %s \n");
   exit(-2);
  }

  yyparse();
  printf("presione una tecla para continuar");
  getch();
  fclose(yyin);
}

