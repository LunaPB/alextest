%{
/* Reconocedor lexico Musim */
#include "c:\tc\bin\bison\pic2.h"
int nlinea=1;
%}
%%
"DEFINE"  {return DEF;}
"MAIN"    {return PMR;}
"AVANZA"      {return AVA;}
"DERECHA"     {return DER;}
"IZQUIERDA"   {return IZQ;}
[a-z] {yylval.identificador=yytext[0];return ID;}
[0-9] {yylval.constante=yytext[0];return NUM;}
[+] {return ADD;}
[=] {return IGU;}
[(] {return PAI;}
[)] {return PAD;}
[{] {return LLI;}
[}] {return LLD;}
[;] {return PCO;}
[W] {return PRW;}
[R] {return PRR;}
[\n]  {nlinea++;}
%%
