%{
int valor=0;
%}

imayor[VXLCDM]
vmayor[XLCDM]
xmayor[LCDM]
lmayor[CDM]
cmayor[DM]
finlinea \n
%%
I valor ++;
V valor=valor+5;
X valor=valor+10;
L valor=valor+50;
C valor=valor+100;
D valor=valor+500;
M
I{imayor}
V{vmayor}
X/{xmayor}
L/{lmayor}
C{cmayor}
D/M
{finlinea}
%%
main()
{
 while (yylex());
}
valor=valor+1000;
valor--;
yyless(1);
valor=valor-5;
yyless(1);
valor=valor-20;
valor=valor-50;
valor=valor-100;
yyles(1);
valor=valor-500;
{
  if(valor!=0)
    printf("decimal:%d\n\n\r",valor);
    valor=0;
}